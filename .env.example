# ROTATION POLICY: If any key in this file is ever found in plaintext in a note, transcript, or log, rotate it immediately at the provider console. Keys in this file are examples only — never commit a real key.

# Anthropic API key (sk-ant-api03-* pattern) for Claude / transcript analysis tooling
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI / Gemini API key (AIzaSy* pattern)
GOOGLE_API_KEY=your_google_api_key_here

# AWS access key ID (AKIA* pattern) for AWS-backed services
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application ID (from Discord Developer Portal > General Information)
DISCORD_CLIENT_ID=your_discord_client_id_here

# Podcast Index API credentials (https://podcastindex.org/developer)
PODCAST_INDEX_API_KEY=your_api_key_here
PODCAST_INDEX_API_SECRET=your_api_secret_here

# Alby API token for boostagram polling (https://getalby.com)
ALBY_ACCESS_TOKEN=your_alby_token_here

# aegis-os backend URL (the running instance on chantecler-01 or localhost)
AEGIS_OS_URL=http://67.205.162.200:3000
AEGIS_OS_WS_URL=ws://67.205.162.200:3000

# SQLite database path for bot state
DB_PATH=./data/bot.db

# Polling intervals (ms)
EPISODE_POLL_INTERVAL_MS=600000
BOOST_POLL_INTERVAL_MS=60000

# Cache TTL for /status results (ms)
STATUS_CACHE_TTL_MS=3600000

# Minimum boost amount to display (sats) — fail-closed guard
MIN_BOOST_DISPLAY_SATS=1

# Bot environment (development | production)
NODE_ENV=development
